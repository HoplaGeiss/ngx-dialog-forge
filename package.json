{
  "name": "ngx-dialog-forge",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoplaGeiss/ngx-dialog-forge.git"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build": "ng build demo",
    "build:lib": "ng build ngx-dialog-forge",
    "watch": "ng build demo --watch --configuration development",
